{
  "models": {
    "mode": "merge",
    "providers": {
      "zhipu": {
        "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "YOUR_GLM_API_KEY_HERE",
        "api": "openai-completions",
        "models": [
          {
            "id": "zhipu/glm-4",
            "name": "GLM-4",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0.001, "output": 0.001 },
            "contextWindow": 128000,
            "maxTokens": 4096
          },
          {
            "id": "zhipu/glm-4-air",
            "name": "GLM-4-Air",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0.0001, "output": 0.0001 },
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "zhipu/glm-4",
        "fallbacks": ["zhipu/glm-4-air"]
      },
      "workspace": "REPLACE_WITH_FULL_PATH/workspace",
      "compaction": { "mode": "safeguard" },
      "maxConcurrent": 4,
      "subagents": { "maxConcurrent": 8 }
    },
    "list": [
      {
        "id": "main",
        "name": "FORGE Orchestrator",
        "default": true,
        "identity": { "name": "FORGE", "emoji": "🦞" },
        "subagents": { "allowAgents": ["*"] }
      },
      {
        "id": "pm-agent",
        "name": "Project Manager",
        "identity": { "name": "PM", "emoji": "📋" }
      },
      {
        "id": "architect-agent",
        "name": "Architect",
        "identity": { "name": "Architect", "emoji": "🏗️" }
      },
      {
        "id": "developer-agent",
        "name": "Developer",
        "identity": { "name": "Developer", "emoji": "💻" }
      },
      {
        "id": "tester-agent",
        "name": "Tester",
        "identity": { "name": "Tester", "emoji": "🧪" }
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "YOUR_FORGE_ORCHESTRATOR_BOT_TOKEN",
      "dmPolicy": "pairing",
      "accounts": {
        "pm": {
          "botToken": "YOUR_PM_BOT_TOKEN"
        },
        "architect": {
          "botToken": "YOUR_ARCHITECT_BOT_TOKEN"
        },
        "developer": {
          "botToken": "YOUR_DEVELOPER_BOT_TOKEN"
        },
        "tester": {
          "botToken": "YOUR_TESTER_BOT_TOKEN"
        }
      },
      "streaming": "off"
    }
  },
  "bindings": [
    {
      "match": { "channel": "telegram", "accountId": "pm" },
      "agentId": "pm-agent"
    },
    {
      "match": { "channel": "telegram", "accountId": "architect" },
      "agentId": "architect-agent"
    },
    {
      "match": { "channel": "telegram", "accountId": "developer" },
      "agentId": "developer-agent"
    },
    {
      "match": { "channel": "telegram", "accountId": "tester" },
      "agentId": "tester-agent"
    }
  ],
  "messages": { "ackReactionScope": "all" },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": { "session-memory": { "enabled": true } }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback"
  }
}
